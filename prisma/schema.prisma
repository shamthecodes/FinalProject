generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())

  orders   Order[]
  wishlist Wishlist[]
  cart     Cart[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  mrp         Float
  images      String[]
  category    String
  metal       String
  stone       String?
  weight      Float?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  orderItems OrderItem[]
  wishlist   Wishlist[]
  cartItems  Cart[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        String      @default("confirmed")
  total         Float
  paymentMethod String
  paymentId     String?
  address       Json
  createdAt     DateTime    @default(now())

  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model Cart {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
}